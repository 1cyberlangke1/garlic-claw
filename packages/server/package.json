{
  "name": "@garlic-claw/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch & node --watch dist/src/main.js",
    "start": "node dist/src/main.js",
    "smoke:http": "node scripts/http-smoke.mjs",
    "smoke:http:core": "node scripts/http-smoke.mjs --profile core",
    "smoke:http:full": "node scripts/http-smoke.mjs --profile full",
    "smoke:http:real": "node scripts/http-smoke.mjs --real-provider-env",
    "test": "jest --runInBand --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.41",
    "@garlic-claw/plugin-sdk": "*",
    "@garlic-claw/shared": "*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "ai": "^6.0.116",
    "ajv": "^8.18.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron-parser": "^5.5.0",
    "diff": "^7.0.0",
    "just-bash": "^2.14.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-powershell": "^0.26.3",
    "uuidv7": "^1.2.1",
    "web-tree-sitter": "^0.26.8",
    "ws": "^8.19.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "overrides": {
    "ajv": "8.18.0",
    "ajv@6": "8.18.0",
    "ajv@7": "8.18.0",
    "@angular-devkit/core": {
      "ajv": "8.18.0"
    }
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.3.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.3"
  }
}
