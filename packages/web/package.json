{
  "name": "@garlic-claw/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prebuild": "cd ../.. && npm run build -w packages/shared",
    "dev": "vite",
    "lint": "cd ../.. && eslint --cache --cache-strategy content --cache-location .cache/eslint \"packages/web/src/**/*.ts\"",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "smoke:browser": "node tests/smoke/browser-smoke.mjs",
    "smoke:browser:artifacts": "node tests/smoke/browser-smoke.mjs --artifact-mode always"
  },
  "dependencies": {
    "@garlic-claw/shared": "*",
    "@iconify-icons/solar": "^1.2.3",
    "@iconify/types": "^2.0.0",
    "@iconify/vue": "^5.0.0",
    "@tanstack/vue-virtual": "^3.13.23",
    "dompurify": "^3.4.2",
    "element-plus": "^2.13.7",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "pinia": "^3.0.0",
    "pinyin-pro": "^3.28.1",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "postcss-custom-media": "^12.0.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.0"
  }
}
