# 运行环境
NODE_ENV=development
PORT=23330
WS_PORT=23331
CORS_ORIGIN=*

# 单密钥登录
GARLIC_CLAW_LOGIN_SECRET=change-me-to-a-secure-shared-secret
GARLIC_CLAW_AUTH_TTL=30d

# JWT
JWT_SECRET=change-me-to-a-secure-random-string

# 远程插件接入（可选）
REMOTE_PLUGIN_WS_URL=
REMOTE_PLUGIN_TOKEN_EXPIRES_IN=30d

# AI 配置路径（默认 config/ai/）
# GARLIC_CLAW_AI_SETTINGS_PATH=config/ai

# 如有 MCP 或自定义 provider 需要读环境变量，自行追加密钥
