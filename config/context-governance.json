{
  "conversationTitle": {
    "enabled": true,
    "defaultTitle": "New Chat",
    "maxMessages": 3
  },
  "contextCompaction": {
    "enabled": true,
    "strategy": "summary",
    "compressionThreshold": 72,
    "keepRecentMessages": 2,
    "frontendMessageWindowSize": 200,
    "reservedTokens": 12000,
    "slidingWindowUsagePercent": 50,
    "summaryPrompt": "请把下面这段历史对话整理成可供后续继续回答的上下文摘要。",
    "showCoveredMarker": true,
    "allowAutoContinue": true
  }
}
