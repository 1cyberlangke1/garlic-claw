# Git 忽略文件

# Node.js 相关
node_modules/
package-lock.json
dist/
packages/*/dist/
packages/server/tmp/
workspace/
log/
packages/*/node_modules/.cache/
packages/web/node_modules/.vite/
packages/web/node_modules/.vite-temp/

# TypeScript 编译产物
**/*.js.map
**/*.d.ts.map
**/*.tsbuildinfo

# 防止编译产物混入 src（shared 包曾经误生成）
packages/shared/src/**/*.js
packages/shared/src/**/*.d.ts

.env
.run.pid
*.log
coverage/
.turbo/
*.db
*.db-journal
config/ai-settings.json
config/model-capabilities.json
config/tool-governance.json
config/skill-governance.json

# config/ 下的本机真实配置默认不提交；仓库内置样例/默认配置显式放行
config/ai/providers/*.json
config/ai/host-model-routing.json
config/ai/vision-fallback.json

config/mcp/servers/*.json
!config/mcp/servers/tavily-mcp.json

config/personas/*
!config/personas/builtin.default-assistant/
config/personas/builtin.default-assistant/*
!config/personas/builtin.default-assistant/avatar.png
!config/personas/builtin.default-assistant/persona.json
!config/personas/builtin.default-assistant/prompt.md

config/subagent/*
!config/subagent/general/
!config/subagent/explore/
config/subagent/general/*
config/subagent/explore/*
!config/subagent/general/subagent.json
!config/subagent/explore/subagent.json
!config/subagent/explore/prompt.md

# Python 相关
*.pyc
__pycache__/
venv/
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Skill 产物（仅本地协作使用，不提交 git）
task_plan.md
progress.md
findings.md
tmp/
docs/superpowers/
.worktrees/

# 系统自带
.DS_Store

# 其他
other/
.cache/
